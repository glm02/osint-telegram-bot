# Bot Telegram (BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# URL publique Render (ex: https://osint-bot-xxxx.onrender.com)
# Laisser vide pour mode polling en local
WEBHOOK_URL=https://your-app.onrender.com

# HaveIBeenPwned API (~3.50$/mois)
HIBP_API_KEY=your_hibp_api_key_here

# Veriphone API (1000 req/mois gratuit)
VERIPHONE_API_KEY=your_veriphone_api_key_here

# Ton user ID Telegram (séparés par virgule si plusieurs admins)
ADMIN_IDS=123456789

# Port serveur (Render le fournit automatiquement)
PORT=8080
